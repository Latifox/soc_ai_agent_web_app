<?xml version="1.0"?>
<!-- Allow browser-based UIs (Tabix, etc.) to query ClickHouse over HTTP by adding
     CORS headers to responses for the default profile. -->
<clickhouse>
    <profiles>
        <default>
            <add_http_cors_header>1</add_http_cors_header>
        </default>
    </profiles>
</clickhouse>
