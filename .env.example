# ════════════════════════════════════════════════════════════════════════
# Aegis — single unified env for ALL services (web, api, agents).
#
# LOCAL DEV: copy to `.env` at the repo root. The web app (apps/web) loads this
# root file via next.config.ts, so there is no separate apps/web/.env.
#
# RAILWAY (or any PaaS): create three services from this repo and set these vars
# on each. The groups below say which service needs which. Railway injects PORT —
# start commands read it. See DEPLOY.md.
# ════════════════════════════════════════════════════════════════════════

# ─── Core (all services) ────────────────────────────────────────────────
AEGIS_ENV=dev                      # dev | staging | prod
AEGIS_SECRET_KEY=change-me

# ─── Supabase — auth + metadata Postgres (all services) ─────────────────
# Hosted project (cloud). The web needs the NEXT_PUBLIC_* pair; api/agents need
# the JWT secret (to verify tokens) and PG_URL (durable store).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
PG_URL=postgresql://postgres:postgres@db.YOUR-PROJECT.supabase.co:5432/postgres
PERSISTENCE=postgres               # postgres (durable, prod) | memory (volatile dev/tests)
SEED_DEMO=false                    # true only to load demo SOC data; keep false in prod

# Web (apps/web) — public, inlined at build. Same project as SUPABASE_* above.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Service URLs (wire the three deploys together) ─────────────────────
# Web → API. Set to the API service's public URL on Railway.
AEGIS_API_URL=http://localhost:8000
# API → AgentOS (the crew runtime).
AGENTOS_URL=http://localhost:7777
AGENTOS_SECURITY_KEY=change-me
# Optional dev-only bearer for the web BFF before Supabase is wired (leave blank in prod).
AEGIS_DEV_TOKEN=

# ─── OpenSearch — remote/managed cluster (api + agents) ─────────────────
# No local Docker. Point at your managed cluster (Aiven / AWS OpenSearch / self-hosted).
OPENSEARCH_URL=https://your-cluster.example.com:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=
OPENSEARCH_EVENTS_SUFFIX=events

# Optional: official OpenSearch MCP server for richer crew tools (agents).
AEGIS_MCP_ENABLED=0                 # 1 to enable; run mcp_server_opensearch separately
OPENSEARCH_MCP_URL=http://localhost:9900/mcp

# ─── LLM provider (agents; api for the assistant) ───────────────────────
# openrouter (default): one key, any model. Tenants may also supply their own
# OpenRouter key from the web Integrations page (per-tenant override).
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=                  # only if LLM_PROVIDER=anthropic
MODEL_REASONER=anthropic/claude-sonnet-4.5
MODEL_BALANCED=anthropic/claude-sonnet-4.5
MODEL_FAST=anthropic/claude-haiku-4.5
MODEL_ASSISTANT=anthropic/claude-sonnet-4.5

# ─── Object store (local archive; no S3 required) ───────────────────────
STORAGE_BACKEND=local              # local | supabase | s3
STORAGE_LOCAL_PATH=./data/storage

# ─── Observability (optional, agents) ───────────────────────────────────
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─── Threat intel (optional, agents) ────────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
MISP_URL=
MISP_API_KEY=
