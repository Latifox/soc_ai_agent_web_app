# ─── Core ───────────────────────────────────────────────────────────────
AEGIS_ENV=dev
AEGIS_SECRET_KEY=change-me

# ─── Postgres (app metadata + RLS) ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis
PG_URL=postgresql+psycopg://aegis:aegis@localhost:5432/aegis

# ─── ClickHouse (events datalake) ───────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=aegis

# ─── OpenSearch (search + federation) ───────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Object store (S3 / MinIO) ──────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aegis

# ─── Auth (Keycloak OIDC) ───────────────────────────────────────────────
OIDC_ISSUER=http://localhost:8080/realms/aegis
OIDC_CLIENT_ID=aegis-web
OIDC_CLIENT_SECRET=change-me

# ─── LLM (Anthropic / Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
MODEL_REASONER=claude-fable-5
MODEL_BALANCED=claude-sonnet-5
MODEL_FAST=claude-haiku-4-5-20251001

# ─── AgentOS ────────────────────────────────────────────────────────────
AGENTOS_PORT=7777
AGENTOS_SECURITY_KEY=change-me

# ─── Observability (Langfuse) ───────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─── Threat intel ───────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
MISP_URL=
MISP_API_KEY=
