# ─── Core ───────────────────────────────────────────────────────────────
AEGIS_ENV=dev
AEGIS_SECRET_KEY=change-me

# ─── Supabase (app metadata Postgres + RLS + Auth) ──────────────────────
# Local dev: `supabase start` (Supabase CLI). Prod: your hosted project.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
# Direct Postgres connection (metadata store + Agno PostgresDb)
PG_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres
# Metadata store: "memory" (dev/tests, volatile) or "postgres" (Supabase, durable/prod).
PERSISTENCE=memory
# Frontend (Next.js) — public
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── OpenSearch (logs + search + detection — the sole telemetry store) ──
# Point at a local service (infra/docker-compose) or a managed/remote cluster.
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
# OpenSearch Agent Server (MCP tool layer, `opensearch-agent-server --with-mcp`)
OPENSEARCH_AGENT_SERVER_URL=http://localhost:8001

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Object store (LOCAL for now — no S3) ───────────────────────────────
STORAGE_BACKEND=local              # local | supabase | s3  (local = ./data, no S3)
STORAGE_LOCAL_PATH=./data/storage
# Prod later: STORAGE_BACKEND=s3 (+ S3_ENDPOINT/S3_ACCESS_KEY/S3_SECRET_KEY/S3_BUCKET)

# ─── Auth ───────────────────────────────────────────────────────────────
# Handled by Supabase Auth (see SUPABASE_* above). Enterprise SSO (SAML/OIDC)
# and SCIM are configured per-tenant in the Supabase project / dashboard.

# ─── LLM provider ───────────────────────────────────────────────────────
# openrouter (default): one key, any model (https://openrouter.ai/models)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=                 # only if LLM_PROVIDER=anthropic
MODEL_REASONER=anthropic/claude-sonnet-4.5
MODEL_BALANCED=anthropic/claude-sonnet-4.5
MODEL_FAST=anthropic/claude-haiku-4.5

# ─── AgentOS ────────────────────────────────────────────────────────────
AGENTOS_PORT=7777
AGENTOS_SECURITY_KEY=change-me

# ─── Observability (Langfuse) ───────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─── Threat intel ───────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
MISP_URL=
MISP_API_KEY=
